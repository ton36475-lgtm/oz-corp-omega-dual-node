# sirinx-app — Local Environment Variables
# Copy to .env.local and fill in your values
# The app works WITHOUT these keys (mock data mode)
# Add keys to switch to live Supabase data immediately

# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# ── AI Models ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
XAI_API_KEY=your-xai-api-key-here

# ── Zhipu AI — GLM-5V-Turbo (Vision + Multimodal) ─────────────────────────
# สมัครที่ https://open.bigmodel.cn/
# หรือใช้ผ่าน OpenRouter: https://openrouter.ai/ (model: z-ai/glm-5v-turbo)
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_BASE_URL=https://api.z.ai/api/paas/v4   # mirror URL (alternative)
OPENROUTER_API_KEY=your-openrouter-api-key-here  # fallback if no ZHIPU_API_KEY

# ── OpenClaw (local CLI; never commit real keys) ────────────────────────────
OPENCLAW_API_KEY=your-openclaw-api-key-here
# Full path to openclaw binary or openclaw.cmd (required for /api/openclaw/run)
# OPENCLAW_EXECUTABLE=/usr/local/bin/openclaw
